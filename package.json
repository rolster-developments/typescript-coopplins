{
  "name": "@rolster/coopplins-server",
  "version": "5.8.2",
  "type": "module",
  "description": "Package that contains a working environment to develop web applications and API's.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.cjs",
        "import": "./dist/es/index.mjs"
      },
      "default": "./dist/es/index.mjs"
    },
    "./types": {
      "types": "./dist/esm/types.d.ts",
      "node": {
        "require": "./dist/cjs/types.cjs",
        "import": "./dist/es/types.mjs"
      },
      "default": "./dist/es/types.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@rolster/commons": "^4.1.2",
    "@rolster/invertly": "^4.3.1",
    "@sentry/node": "^10.10.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-validator": "^7.3.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolster/rollup": "^2.1.1",
    "@rolster/types": "^1.1.1",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-coopplins.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "coopplins",
    "express",
    "http",
    "web-service"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
